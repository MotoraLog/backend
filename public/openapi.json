                ]
              }
            }
          }
        }
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Status da API"
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Cria um novo usuário",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8
                  }
                },
                "required": [
                  "name",
                  "email",
                  "password"
                ]
              },
              "examples": {
                "default": {
                  "$ref": "#/components/examples/RegisterRequest"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuário criado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "user": {
                          "$ref": "#/components/schemas/User"
                        },
                        "tokens": {
                          "$ref": "#/components/schemas/Tokens"
                        }
                      },
                      "required": [
                        "user",
                        "tokens"
                      ]
                    }
                  },
                  "required": [
                    "data"
                  ]
                },
                "examples": {
                  "success": {
                    "$ref": "#/components/examples/AuthSuccessResponse"
                  }
                }
              }
            }
          },
          "409": {
            "description": "Email duplicado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "duplicate": {
                    "$ref": "#/components/examples/ErrorValidation"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Autentica usuário",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              },
              "examples": {
                "default": {
                  "value": {
                    "email": "gilberto@example.com",
                    "password": "supersecret123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Login realizado",
            "content": {
              "application/json": {
                "examples": {
                  "success": {
                    "$ref": "#/components/examples/AuthSuccessResponse"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Credenciais inválidas",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "unauthorized": {
                    "$ref": "#/components/examples/ErrorUnauthorized"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "summary": "Renova os tokens de autenticação",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "refreshToken": {
                    "type": "string"
                  }
                },
                "required": [
                  "refreshToken"
                ]
              },
              "examples": {
                "default": {
                  "value": {
                    "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.refresh"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tokens renovados",
            "content": {
              "application/json": {
                "examples": {
                  "success": {
                    "$ref": "#/components/examples/AuthSuccessResponse"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Refresh token inválido",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "summary": "Retorna o usuário autenticado",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Usuário atual",
            "content": {
              "application/json": {
                "examples": {
                  "success": {
                    "value": {
                      "data": {
                        "user": {
                          "id": "67ea9f3f4e4f2f0012ab34cd",
                          "email": "gilberto@example.com",
                          "name": "Gilberto"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Não autenticado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "unauthorized": {
                    "$ref": "#/components/examples/ErrorUnauthorized"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/vehicles": {
      "get": {
        "summary": "Lista veículos com paginação e busca",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "page",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "in": "query",
            "name": "pageSize",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 100
            }
          },
          {
            "in": "query",
            "name": "search",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de veículos paginada",
            "content": {
              "application/json": {
                "examples": {
                  "success": {
                    "$ref": "#/components/examples/VehicleListResponse"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Cria um veículo",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "plate": {
                    "type": "string"
                  },
                  "category": {
                    "type": "string",
                    "default": "car"
                  },
                  "currentOdometerKm": {
                    "type": "number",
                    "default": 0
                  }
                },
                "required": [
                  "description",
                  "plate"
                ]
              },
              "examples": {
                "default": {
                  "$ref": "#/components/examples/VehicleCreateRequest"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Veículo criado",
            "content": {
              "application/json": {
                "examples": {
                  "success": {
                    "value": {
                      "data": {
                        "vehicle": {
                          "id": "67ea9f3f4e4f2f0012ab3411",
                          "userId": "67ea9f3f4e4f2f0012ab34cd",
                          "description": "Civic Touring 2020",
                          "plate": "ABC1D23",
                          "category": "car",
                          "currentOdometerKm": 102350,
                          "createdAt": "2026-03-27T12:00:00.000Z",
                          "updatedAt": "2026-03-27T12:30:00.000Z"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/vehicles/{vehicleId}": {
      "parameters": [
        {
          "name": "vehicleId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Retorna um veículo",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Veículo"
          },
          "404": {
            "description": "Veículo não encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Atualiza parcialmente um veículo",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Veículo atualizado"
          },
          "409": {
            "description": "Regressão de hodômetro"
          }
        }
      },
      "delete": {
        "summary": "Remove um veículo",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Veículo removido"
          }
        }
      }
    },
    "/api/vehicles/{vehicleId}/odometer": {
      "post": {
        "summary": "Atualiza a quilometragem do veículo",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "vehicleId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Hodômetro atualizado",
            "content": {
              "application/json": {
                "examples": {
                  "success": {
                    "value": {
                      "data": {
                        "vehicle": {
                          "id": "67ea9f3f4e4f2f0012ab3411",
                          "userId": "67ea9f3f4e4f2f0012ab34cd",
                          "description": "Civic Touring 2020",
                          "plate": "ABC1D23",
                          "category": "car",
                          "currentOdometerKm": 102800
                        },
                        "odometerUpdate": {
                          "id": "67ea9f3f4e4f2f0012ab3800",
                          "userId": "67ea9f3f4e4f2f0012ab34cd",
