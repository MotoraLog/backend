            "details": null
          }
        }
      },
      "ErrorValidation": {
        "summary": "Erro de validacao",
        "value": {
          "error": {
            "message": "Validation failed.",
            "code": "VALIDATION_ERROR",
            "details": {
              "formErrors": [],
              "fieldErrors": {
                "email": [
