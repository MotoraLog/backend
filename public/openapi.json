{
  "openapi": "3.1.0",
  "info": {
    "title": "Vehicle Maintenance Backend API",
    "version": "0.2.0",
    "description": "API serverless para autenticação, veículos, hodômetro, abastecimentos, manutenções e lembretes."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Desenvolvimento local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "code": {
                "type": "string"
              },
              "details": {}
            },
            "required": [
              "message",
              "code",
              "details"
            ]
          }
        },
        "required": [
          "error"
        ]
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "minimum": 1
          },
          "pageSize": {
            "type": "integer",
            "minimum": 1
          },
          "totalItems": {
            "type": "integer",
            "minimum": 0
          },
          "totalPages": {
            "type": "integer",
            "minimum": 1
          }
        },
        "required": [
          "page",
          "pageSize",
          "totalItems",
          "totalPages"
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "name"
        ]
      },
      "Tokens": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "accessToken",
          "refreshToken"
        ]
      },
      "Vehicle": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "plate": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "currentOdometerKm": {
            "type": "number"
          },
          "createdAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "updatedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "userId",
          "description",
          "plate",
          "category",
          "currentOdometerKm"
        ]
      },
      "FuelEntry": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "vehicleId": {
            "type": "string"
          },
          "odometerKm": {
            "type": "number"
          },
          "unitPrice": {
            "type": "number"
          },
          "fuelType": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "totalPrice": {
            "type": "number"
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          },
          "recordedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "createdAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "userId",
          "vehicleId",
          "odometerKm",
          "unitPrice",
          "fuelType",
          "quantity",
          "totalPrice"
        ]
      },
      "MaintenanceEntry": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "vehicleId": {
            "type": "string"
          },
          "maintenanceType": {
            "type": "string"
          },
          "odometerKm": {
            "type": "number"
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          },
          "performedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "createdAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "userId",
          "vehicleId",
          "maintenanceType",
          "odometerKm"
        ]
      },
      "Reminder": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "vehicleId": {
            "type": "string"
          },
          "reminderText": {
            "type": "string"
          },
          "currentOdometerKm": {
            "type": "number"
          },
          "mileageIntervalKm": {
            "type": [
              "number",
              "null"
            ]
          },
          "remindAtOdometerKm": {
            "type": [
              "number",
              "null"
            ]
          },
          "monthInterval": {
            "type": [
              "number",
              "null"
            ]
          },
          "remindAtDate": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "status": {
            "type": "string"
          },
          "createdAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "updatedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "dueState": {
            "type": "object",
            "properties": {
              "dueByMileage": {
                "type": "boolean"
              },
              "dueByDate": {
                "type": "boolean"
              },
              "isDue": {
                "type": "boolean"
              }
            },
            "required": [
              "dueByMileage",
              "dueByDate",
              "isDue"
            ]
          }
        },
        "required": [
          "id",
          "userId",
          "vehicleId",
          "reminderText",
          "currentOdometerKm",
          "status",
          "dueState"
        ]
      }
    },
    "examples": {
